{
  "env": "dev",
  "base_url": "https://customcraft-mes.ru",
  "http_timeout_s": 8,
  "state_file": "state.json",
  "users_cache_file": "users_cache.json",
  "users_cache_ttl_s": 300,
  "tts_prefer_edge": true,
  "tts_edge_voice": "ru-RU-DmitryNeural",
  "updater": {
    "enabled": true,
    "check_on_startup": true,
    "github_owner": "bellenne",
    "github_repo": "scanserver",
    "github_token": "",
    "asset_name": "ScanServer-windows-x64.zip",
    "allow_prerelease": false,
    "executable_name": "ScanServer.exe",
    "preserve_files": [
      "config.json",
      "state.json",
      "users_cache.json"
    ],
    "preserve_dirs": [
      ".tts_cache"
    ]
  },
  "scanners": [
    {
      "device_id": "BG01",
      "com_port": "COM3",
      "baudrate": 9600
    }
  ],
  "endpoints": {
    "events": "/api/v1/cut/scan",
    "transfer": "/api/v1/transfer/scan",
    "defect": "/api/v1/cut/scan",
    "package": "/api/v1/package/scan"
  }
}
